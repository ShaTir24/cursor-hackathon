# Copy to docker-compose.env and fill values (never commit secrets).
# Also used by Compose build args for the Next.js image.

# --- Supabase (required for real Sign in / Sign up) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET_FROM_SUPABASE_SETTINGS

# Nest reaches itself from the browser via host-mapped port
NEXT_PUBLIC_API_BASE=http://localhost:3000

# Real product demo: require Supabase JWTs (no guest x-user-id).
AUTH_DEV_BYPASS=false
NEXT_PUBLIC_AUTH_DEV_BYPASS=false

# Optional Nest integrations
EXA_ENABLED=false
EXA_API_KEY=
TTS_FORCE_FIXTURES=true
# Nest API; web compose overrides NODE_ENV=development for hot reload
NODE_ENV=production
DATABASE_URL=

# HLS demo: pack backend/data/demo-source.mp4 (or any data/*.mp4) into /media/{id}/index.m3u8
# auto = use MP4 when present; true = require it; false = always use scene+TTS pipeline
HLS_USE_DEMO_MP4=auto
HLS_DEMO_MP4=/app/data/demo-source.mp4

# MentorScroll / Cursor CLI video creation
MIXAMO_ACCESS_TOKEN=
ELEVENLABS_API_KEY=
CURSOR_API_KEY=
# Shared secret for POST /api/v1/video-creation (send as x-api-key header)
VIDEO_CREATION_API_KEY=
# Optional: absolute path for video-workspaces parent (defaults to project root)
# VIDEO_WORKSPACES_DIR=
