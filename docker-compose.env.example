# Copy to docker-compose.env and fill values (never commit secrets).
# Also used by Compose build args for the Next.js image.

# --- Supabase (browser + Nest JWT verify) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET_FROM_SUPABASE_SETTINGS

# Nest reaches itself from the browser via host-mapped port
NEXT_PUBLIC_API_BASE=http://localhost:3000

# Local demos without Supabase Auth (web + Nest must both enable)
# AUTH_DEV_BYPASS=true
# NEXT_PUBLIC_AUTH_DEV_BYPASS=true

# Optional Nest integrations
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
EXA_ENABLED=false
EXA_API_KEY=
TTS_FORCE_FIXTURES=true
NODE_ENV=production
DATABASE_URL=
