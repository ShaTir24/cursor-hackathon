PORT=3000

# Supabase (JWT verify + optional admin client — never commit real values)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional HS256 fallback if JWKS is unavailable
SUPABASE_JWT_SECRET=

# Local demos without Supabase Auth (require header x-user-id)
# AUTH_DEV_BYPASS=true

# Media / TTS
HLS_ROOT=
TTS_CACHE_DIR=
FFMPEG_PATH=ffmpeg
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5
TTS_DAILY_CHAR_BUDGET=50000
# TTS_FORCE_FIXTURES=true

# Optional research enrichment
EXA_ENABLED=false
EXA_API_KEY=

# MentorScroll / Cursor CLI video creation
MIXAMO_ACCESS_TOKEN=
CURSOR_API_KEY=
# Shared secret for POST /api/v1/video-creation (send as x-api-key header)
VIDEO_CREATION_API_KEY=
# Optional: absolute path for video-workspaces parent (defaults to project root)
# VIDEO_WORKSPACES_DIR=
