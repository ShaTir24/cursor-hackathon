PORT=3000

# Supabase (server-only — never commit real values)
# Project URL example: https://ihbfdnajyiqouobjwtbp.supabase.co
SUPABASE_URL=
# Service role key from Supabase Dashboard → Project Settings → API
# Required for Nest to read/write profiles (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: fall back to in-memory profiles when unset (local unit tests only)
# USE_MEMORY_PROFILES=true
